{
  "schemaVersion": 1,
  "id": "carrybabyanimals",
  "version": "${version}",
  "name": "Carry Baby Animals",
  "description": "Carry and pet baby animals without putting them in your inventory.",
  "authors": ["Tyler", "Jasmine"],
  "contact": {
    "homepage": "https://modrinth.com/mod/carrybabyanimals",
    "sources": "https://github.com/TnTBass/carrybabyanimals",
    "issues": "https://github.com/TnTBass/carrybabyanimals/issues"
  },
  "license": "MIT",
  "icon": "assets/carrybabyanimals/icon_128.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.jasmine.carrybabyanimals.fabric.CarryBabyAnimalsFabric"
    ],
    "client": [
      "dev.jasmine.carrybabyanimals.client.CarryBabyAnimalsClient"
    ],
    "modmenu": [
      "dev.jasmine.carrybabyanimals.client.config.CarryBabyAnimalsModMenuIntegration"
    ]
  },
  "mixins": [
    "carrybabyanimals.mixins.json",
    {
      "config": "carrybabyanimals.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "fabric-permissions-api-v0": ">=0.7.0",
    "modmenu": "*"
  }
}
